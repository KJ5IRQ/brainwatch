# Copy to ~/.config/brainwatch/env and edit.
# This file is sourced by the systemd service.
# Lines starting with # are comments; empty lines are ignored.

# Path to your Brainwatch config TOML (optional; defaults to XDG paths)
# BRAINWATCH_CONFIG=/home/you/.config/brainwatch/config.toml

# Provider API keys — one per provider defined in your config.toml.
# Omit any you are not using.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# EXAMPLE_PROVIDER_API_KEY=your-custom-key
